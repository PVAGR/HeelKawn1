; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="HeelKawn"
config/description="The Grand Synthesis - hybrid colony/strategy/RPG simulation."
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility", "C#")

[autoload]

# === ESSENTIAL CORE AUTOLOADS (20 total) ===
TickManager="*res://autoloads/TickManager.gd"
GameManager="*res://autoloads/GameManager.gd"
JobManager="*res://dotnet/CJobManager.cs"
StockpileManager="*res://autoloads/StockpileManager.gd"
ZoneRegistry="*res://autoloads/ZoneRegistry.gd"
BuildingRegistry="*res://autoloads/BuildingRegistry.gd"
ColonySimServices="*res://autoloads/ColonySimServices.gd"
WorldMemory="*res://dotnet/CWorldMemory.cs"
WorldMeaning="*res://autoloads/WorldMeaning.gd"
WorldPersistence="*res://autoloads/WorldPersistence.gd"
WorldRNG="*res://autoloads/WorldRNG.gd"
WorldClock="*res://autoloads/WorldClock.gd"
SettlementMemory="*res://autoloads/SettlementMemory.gd"
SettlementRegistry="*res://autoloads/SettlementRegistry.gd"
CulturalMemory="*res://autoloads/CulturalMemory.gd"
CulturalStyleManager="*res://autoloads/CulturalStyleManager.gd"
SpatialManager="*res://autoloads/SpatialManager.gd"
SpatialGrid="*res://dotnet/CSpatialGrid.cs"
GameSettings="*res://autoloads/GameSettings.gd"
EventBus="*res://autoloads/EventBus.gd"

# === CORE FEATURES (5 total) ===
KnowledgeSystem="*res://autoloads/KnowledgeSystem.gd"
TechnologySystem="*res://autoloads/TechnologySystem.gd"
CraftingSystem="*res://autoloads/CraftingSystem.gd"
ProgressionSystem="*res://autoloads/ProgressionSystem.gd"
CivilizationStage="*res://autoloads/CivilizationStage.gd"

# === GAMEPLAY SYSTEMS (4 total) ===
FarmingSystem="*res://autoloads/FarmingSystem.gd"
WildlifePopulation="*res://autoloads/WildlifePopulation.gd"
Weather="*res://scenes/world/Weather.gd"
ObjectPool="*res://autoloads/ObjectPool.gd"

# === CONSOLIDATED MANAGERS (11 total) ===
SettlementManager="*res://autoloads/SettlementManager.gd"
AIManager="*res://autoloads/AIManager.gd"
MemoryManager="*res://autoloads/MemoryManager.gd"
SocialManager="*res://autoloads/SocialManager.gd"
FactionManager="*res://autoloads/FactionManager.gd"
UIManager="*res://autoloads/UIManager.gd"
EventManager="*res://autoloads/EventManager.gd"
EconomyManager="*res://autoloads/EconomyManager.gd"
PlayerManager="*res://autoloads/PlayerManager.gd"
PawnManager="*res://autoloads/PawnManager.gd"
ObserverManager="*res://autoloads/ObserverManager.gd"

# === EXPORT UTILITIES (load on-demand via code, not autoload) ===
# ChronicleExport, WorldSeedExport, CharacterExport removed from autoloads
# Use: var exporter = load("res://autoloads/ChronicleExport.gd").new()

# === DEBUG TOOLS (load on-demand via code, not autoload) ===
# CrashTrap, TickMonitor, PlaytestRecorder removed from autoloads
# Use: var monitor = load("res://tools/diagnose/monitor_ticks.gd").new()

# === REMOVED - Consolidated into managers above ===
# SettlementPlanner, SettlementRebirth, SettlementArchitect → SettlementManager
# AIAutoBuild, AILearning, AICooperation, etc. → AIManager
# AgeMemory, IntentMemory, RemnantMemory, etc. → MemoryManager
# KinshipSystem, GrudgeManager, GossipManager, etc. → SocialManager
# FactionRegistry, FactionSystem, AuthoritySystem → FactionManager
# HeelKawnUIManager, UILayoutManager, PawnMoodUI, etc. → UIManager
# WorldEvents, WorldEventSystem, WorldEventSeedManager → EventManager
# TradePlanner, TradeMemory, FoodChainManager, ToolManager → EconomyManager
# PlayerIntentQueue, PlayerGathering, PlayerBuilding, IncarnationManager → PlayerManager
# PawnConsciousness, PawnDialogue, PawnBrainBridge, etc. → PawnManager
# ObserverLens, SimVision, ObservationAPI, DiscoveryGate, FogOfDiscovery → ObserverManager

# === REMOVED - Non-essential for v1 ===
# FragmentationManager, SchismManager, SettlementIdentity, SettlementPersistence
# ReligionLens, SacredGeography, MythAge
# BodyRiskManager, DisasterSystem, CollapseSystem, CataclysmSystem
# GeneticEvolution, HistoricalSimulation, SquadCoordinator, TimeLapseRecorder
# MemorialSystem, BuildingUsageTracker, SnowAccumulation
# MeaningAudioCue, MeaningAmbianceController, CommandAPI, WorldActionLedger
# AIAgentManager, WorldAI (core, kept separate), HeelKawnianMind, HeelKawnianIdentity, HeelKawnianManager, HeelKawnianVoice
# BloodlineSystem, LegacySystem, GrudgeManager, GossipManager, RelationalGraph
# OnboardingSystem, VictorySystem, FactionSystem
# PawnCommunicationLog, PawnChatterBubbles
# EventNotificationOverlay, ModernTheme, PawnMoodUI
# ZoomSystem, PrisonManager, SettlementAIBridge, SettlementPersistenceManager

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
