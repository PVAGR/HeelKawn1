# Godot-specific ignores
*.import
*.pid
*.tmpt
# export_presets.cfg — tracked for CI/Android export (no secrets; keystores are local/CI-only)
godot_vcs_addon/

# Godot editor cache (never commit these)
.godot/
.godot/editor/
.godot/mono/

# Build artifacts and exports
*.exe
*.pck
*.zip
*.bin
*.so
*.dylib
*.dll
builds/
exports/

# Dependencies
res://.godot/
user://*

# Logs
*.log
debug_output.txt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# AI tool artifacts (not meant for version control)
.aider*
.cursor/
.roo/
.qwen/
.sixth/
.letta/
.agents_tmp/

# Temporary / accidental files
$null
*.tmp
