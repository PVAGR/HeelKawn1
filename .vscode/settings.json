{
  "godot_tools.editor_path": "${workspaceFolder}/tools/godot/Godot_v4.6.2-stable_win64_console.exe",
  "files.associations": {
    "*.gd": "gdscript",
    "*.tscn": "gdscene",
    "*.tres": "gdresource"
  },
  "[gdscript]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.semanticHighlighting.enabled": true
  },
  "editor.tabSize": 4,
  "editor.insertSpaces": true
}

